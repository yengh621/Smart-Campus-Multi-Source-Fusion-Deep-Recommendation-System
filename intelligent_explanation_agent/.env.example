# Zhipu GLM / BigModel OpenAI-compatible API
GLM_API_KEY=replace-me
GLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4-flash
GLM_TIMEOUT_SECONDS=60

RECOMMEND_TOPK=10
RECENT_EVENTS_PER_MODALITY=10

# 默认不把原始用户 ID 发送给外部 API
INCLUDE_USER_ID_IN_API=false

# 兼容旧变量名：如果没有设置 GLM_*，系统也会读取 EXPLAIN_*。
# EXPLAIN_API_KEY=replace-me
# EXPLAIN_API_BASE=https://open.bigmodel.cn/api/paas/v4
# EXPLAIN_MODEL=glm-4-flash
